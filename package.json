{
  "name": "@tetherto/wdk-backup-cloud-react-native",
  "version": "1.0.0-beta.1",
  "description": "Production-grade cloud backup SDK for Expo/React Native wallet apps — Google Drive & iCloud providers",
  "license": "Apache-2.0",
  "author": "Tether",
  "keywords": [
    "wallet",
    "backup",
    "cloud",
    "react-native",
    "expo",
    "icloud",
    "google-drive",
    "encrypted",
    "wdk"
  ],
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "lint": "tsc --noEmit"
  },
  "peerDependencies": {
    "react-native-cloud-storage": ">=1.0.0"
  },
  "peerDependenciesMeta": {
    "react-native-cloud-storage": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^20.14.0",
    "jest": "^29.7.0",
    "jest-fetch-mock": "^3.0.3",
    "ts-jest": "^29.1.4",
    "tsup": "^8.1.0",
    "typescript": "^5.5.2"
  },
  "engines": {
    "node": ">=18"
  }
}
